<UserControl x:Class="NetworkSecuritySimulator.UI.Views.DefensePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="400" Width="600" Background="White" Padding="15">
    <StackPanel>
        <TextBlock Text="Defense Mechanism Configuration" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

        <GroupBox Header="Defense Selection" Padding="10" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Available Defenses:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox Name="DefenseCombo" Padding="8,5">
                    <ComboBoxItem>Port Security</ComboBoxItem>
                    <ComboBoxItem>Firewall Rules</ComboBoxItem>
                    <ComboBoxItem>Access Control Lists</ComboBoxItem>
                    <ComboBoxItem>VLAN Segmentation</ComboBoxItem>
                </ComboBox>
                
                <TextBlock Text="Defense Details:" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBlock Name="DefenseDetails" Text="Select a defense to see details..."
                          Background="#F5F5F5" Padding="8" Height="60" TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Target Selection" Padding="10" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Target Device:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ListBox Name="TargetListBox" Height="150">
                    <!-- Devices will be populated here -->
                </ListBox>
            </StackPanel>
        </GroupBox>

        <StackPanel Orientation="Horizontal">
            <Button Content="Apply Defense" Background="#28A745" Foreground="White"
                   Padding="15,8" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button Content="Remove Defense" Background="#DC3545" Foreground="White"
                   Padding="15,8" Margin="0,0,10,0"/>
            <Button Content="Cancel" Background="#6C757D" Foreground="White"
                   Padding="15,8"/>
        </StackPanel>
    </StackPanel>
</UserControl>
