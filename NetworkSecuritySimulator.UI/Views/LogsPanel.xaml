<UserControl x:Class="NetworkSecuritySimulator.UI.Views.LogsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="400" Width="400" Background="White" Padding="15">
    <StackPanel>
        <TextBlock Text="System Logs" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Filter by Severity:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox Name="SeverityFilter" Width="120">
                <ComboBoxItem>All</ComboBoxItem>
                <ComboBoxItem>INFO</ComboBoxItem>
                <ComboBoxItem>WARNING</ComboBoxItem>
                <ComboBoxItem>CRITICAL</ComboBoxItem>
            </ComboBox>
            <Button Content="Refresh" Padding="10,5" Margin="10,0,0,0"/>
        </StackPanel>

        <ListBox Name="LogsListBox" Height="280" Background="#F5F5F5">
            <!-- Logs will be displayed here -->
        </ListBox>

        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Export Logs" Background="#6C757D" Foreground="White" Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="Clear Logs" Background="#DC3545" Foreground="White" Padding="10,5"/>
        </StackPanel>
    </StackPanel>
</UserControl>
