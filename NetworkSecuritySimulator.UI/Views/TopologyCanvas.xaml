<UserControl x:Class="NetworkSecuritySimulator.UI.Views.TopologyCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="500" Width="800" Background="White">
    <Grid>
        <Canvas Name="CanvasArea" Background="#F5F5F5">
            <!-- Network topology elements will be drawn here -->
        </Canvas>
        
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10"
                   Background="White" Padding="10" BorderBrush="#CCCCCC" BorderThickness="1">
            <TextBlock Text="Topology Visualization" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Text="No topology loaded" Foreground="#666666" TextWrapping="Wrap" Width="200"/>
        </StackPanel>
    </Grid>
</UserControl>
