<Window x:Class="NetworkSecuritySimulator.UI.Views.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Security Dashboard" Height="800" Width="1200"
        Background="#F0F0F0" FontFamily="Segoe UI">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <StackPanel Grid.Row="0" Background="#1F1F1F" Padding="15">
            <TextBlock Text="Network Security Simulator Dashboard" 
                       Foreground="White" FontSize="20" FontWeight="Bold"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1" Padding="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.3*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="0.25*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Controls -->
            <StackPanel Grid.Column="0" Background="White" Padding="10" Margin="0,0,10,0"
                       BorderBrush="#D0D0D0" BorderThickness="1">
                <TextBlock Text="Controls" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                
                <GroupBox Header="Topology Selection" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <ComboBox Name="TopologyCombo" />
                        <Button Content="Load" Background="#007ACC" Foreground="White" 
                                Padding="5" Margin="0,5,0,0"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Simulation" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <Button Content="Start" Background="#28A745" Foreground="White" 
                                Padding="5" Margin="0,0,0,5"/>
                        <Button Content="Stop" Background="#DC3545" Foreground="White" 
                                Padding="5" Margin="0,0,0,5"/>
                        <Button Content="Reset" Background="#6C757D" Foreground="White" 
                                Padding="5"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <!-- Center Panel: Visualization -->
            <Border Grid.Column="1" Background="White" BorderBrush="#D0D0D0" BorderThickness="1">
                <Grid>
                    <Canvas Name="VisualizationCanvas" Background="#FAFAFA">
                        <TextBlock Canvas.Left="50" Canvas.Top="50" FontSize="16" Foreground="#999999">
                            Network topology visualization will appear here
                        </TextBlock>
                    </Canvas>
                </Grid>
            </Border>

            <!-- Right Panel: Info -->
            <StackPanel Grid.Column="2" Background="White" Padding="10" Margin="10,0,0,0"
                       BorderBrush="#D0D0D0" BorderThickness="1">
                <TextBlock Text="Information" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                
                <GroupBox Header="Status" Padding="8" Margin="0,0,0,10">
                    <StackPanel FontSize="11">
                        <TextBlock Text="Simulation: Ready" Margin="0,3"/>
                        <TextBlock Text="Devices: 0" Margin="0,3"/>
                        <TextBlock Text="Active Logs: 0" Margin="0,3"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Device States" Padding="8" Margin="0,0,0,10">
                    <StackPanel FontSize="11">
                        <TextBlock Text="Normal: 0" Foreground="Green" Margin="0,3"/>
                        <TextBlock Text="Vulnerable: 0" Foreground="Orange" Margin="0,3"/>
                        <TextBlock Text="Compromised: 0" Foreground="Red" Margin="0,3"/>
                        <TextBlock Text="Offline: 0" Foreground="Gray" Margin="0,3"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#E0E0E0" Height="25">
            <StatusBarItem>
                <TextBlock Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
